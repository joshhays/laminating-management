# PostgreSQL (use locally via Docker, or Railway/Neon in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laminating_management"

# Digital print schedule is at /schedule/digital-print on this app. Optional: only if that UI is on another origin.
# NEXT_PUBLIC_PRINT_SCHEDULER_URL="https://schedule.example.com"

# Optional: only if laminating UI is on another host than this deployment.
# NEXT_PUBLIC_LAMINATING_APP_URL="https://laminating.example.com"

# Print scheduler: login is OFF by default (open /schedule/digital-print). Enable with:
# ENABLE_SCHEDULER_AUTH=true
# SESSION_SECRET="long-random-string"

# Optional: realtime operator presence on the board (Supabase broadcast).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Customer quote letter (/estimates/[id]/quote-letter) ---
# SHOP_NAME="Yorke Printe Shoppe, Inc."
# SHOP_ADDRESS (multi-line in .env): first line, then \n for breaks — e.g. 930 N. Lombard Road\nLombard, IL 60148
# SHOP_PHONE="(630) 627-4960"
# SHOP_FAX="(630) 627-4965"
# SHOP_WEBSITE="www.yorkeprinte.com"
# SHOP_QUOTE_SALESPERSON_NAME="Marc Eltoft"
# SHOP_QUOTE_ESTIMATOR_NAME="Ramses Rendon"
# SHOP_QUOTE_QUOTED_BY_NAME="Marc Eltoft"
# SHOP_QUOTE_SIGN_OFF_FIRST_NAME="Marc"
# Optional overrides (defaults match typical print-shop copy):
# SHOP_QUOTE_TERMS="Line one`nLine two"
# SHOP_QUOTE_INTRO="..."
# SHOP_QUOTE_CONFIDENTIALITY="..."
# SHOP_QUOTE_CLOSING="..."
# SHOP_QUOTE_DISCLAIMER="..."
